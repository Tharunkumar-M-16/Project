PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/readyscore
# Use a long random string (32+ chars). Required — the server refuses to start without it.
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d
CLIENT_URL=http://localhost:5173

# --- Optional: AI features (Ask-AI chat, AI test generation) via OpenAI ---
# Leave blank to disable AI cleanly (the UI hides the AI panels).
OPENAI_API_KEY=
# Model used for AI features (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# --- Dev staff accounts created by the seed (change before production!) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin
MENTOR_USERNAME=rishi
MENTOR_PASSWORD=mentor123
MENTOR_NAME=Rishi Mentor
