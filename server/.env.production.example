# Copy this to server/.env on your Hostinger server and fill in real values.

NODE_ENV=production
PORT=5000

# --- Database ---
# Option A (recommended): MongoDB Atlas free tier connection string
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/readyscore?retryWrites=true&w=majority
# Option B: MongoDB installed on the same VPS
# MONGO_URI=mongodb://127.0.0.1:27017/readyscore

# --- Auth ---
# CHANGE THIS to a long random string in production
JWT_SECRET=please_change_me_to_a_long_random_secret
JWT_EXPIRE=30d

# Your public site URL (used for CORS; same-origin needs no special value)
CLIENT_URL=https://your-domain.com

# --- Optional: AI features via OpenAI (leave blank to disable cleanly) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Staff accounts created by the seed (change before seeding in prod!) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_admin_pw
ADMIN_NAME=Admin
MENTOR_USERNAME=rishi
MENTOR_PASSWORD=change_this_mentor_pw
MENTOR_NAME=Rishi Mentor
